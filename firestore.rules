
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStaff() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    function isBusinessOwner(businessId) {
      return isSignedIn() && (
        businessId == request.auth.uid || 
        (exists(/databases/$(database)/documents/businesses/$(businessId)) && 
         get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid == request.auth.uid)
      );
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    // Businesses
    match /businesses/{businessId} {
      // Allow individual get by ID (ID often matches UID for new profiles)
      allow get: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      
      // Allow listing businesses based on ownership filter
      allow list: if isSignedIn() && (isStaff() || (request.query.limit <= 100 && request.query.filters.ownerUid == request.auth.uid));
      
      // Allow creation if the ownerUid is the current user
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      
      // Allow updates by owner or staff
      allow update: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      
      allow delete: if isStaff();

      // CRM Customers subcollection
      match /customers/{customerId} {
        allow read, write: if isSignedIn() && (businessId == request.auth.uid || isBusinessOwner(businessId) || isStaff());
      }

      // Activity Feed subcollection
      match /activities/{activityId} {
        allow read, write: if isSignedIn() && (businessId == request.auth.uid || isBusinessOwner(businessId) || isStaff());
      }

      // Analytics/SEO Metrics subcollection
      match /seoMetrics/{metricId} {
        allow read, write: if isSignedIn() && (businessId == request.auth.uid || isBusinessOwner(businessId) || isStaff());
      }
    }

    // Public Service Inquiries (Lead Gen)
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // Payment/Subscription Records
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff();
    }
  }
}
