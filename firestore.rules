rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStaff() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    // Businesses
    match /businesses/{businessId} {
      // Allow individual get by ID if user is owner or ID matches UID
      allow get: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      
      // Allow listing businesses if user owns them
      allow list: if isSignedIn() && (isStaff() || resource.data.ownerUid == request.auth.uid);
      
      // Allow creation
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      
      // Allow updates
      allow update: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      
      allow delete: if isStaff();

      // CRM Customers subcollection
      match /customers/{customerId} {
        allow list: if isSignedIn() && (businessId == request.auth.uid || isStaff() || resource.data.ownerUid == request.auth.uid);
        allow get: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
        allow create: if isSignedIn() && (businessId == request.auth.uid || isStaff() || request.resource.data.ownerUid == request.auth.uid);
        allow update: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
        allow delete: if isSignedIn() && (businessId == request.auth.uid || isStaff());
      }

      // Activity Feed subcollection
      match /activities/{activityId} {
        allow list: if isSignedIn() && (businessId == request.auth.uid || isStaff() || resource.data.ownerUid == request.auth.uid);
        allow get: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
        allow create: if isSignedIn() && (businessId == request.auth.uid || isStaff() || request.resource.data.ownerUid == request.auth.uid);
        allow update: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
        allow delete: if isSignedIn() && (businessId == request.auth.uid || isStaff());
      }

      // Analytics/SEO Metrics subcollection
      match /seoMetrics/{metricId} {
        allow list: if isSignedIn() && (businessId == request.auth.uid || isStaff() || resource.data.ownerUid == request.auth.uid);
        allow get: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
        allow write: if isSignedIn() && (businessId == request.auth.uid || isStaff());
      }
    }

    // Public Service Inquiries (Lead Gen)
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // Payment/Subscription Records
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff();
    }
  }
}