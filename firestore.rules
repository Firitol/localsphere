
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Defensive check for ownership
    function isOwner(data) {
      return isSignedIn() && data != null && data.get('ownerUid', '') == request.auth.uid;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    match /businesses/{businessId} {
      // Allow user to get their own business profile or if they are staff
      allow get: if isSignedIn() && (businessId == request.auth.uid || isOwner(resource.data) || isStaff());
      // Allow listing businesses for the dashboard
      allow list: if isSignedIn(); 
      // Allow creation if they set themselves as owner
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Allow updates by owner or staff
      allow update: if isSignedIn() && (isOwner(resource.data) || isStaff() || businessId == request.auth.uid);
      allow delete: if isStaff();

      // Subcollections are private to the business owner or staff
      // Using path-based check (businessId == request.auth.uid) is most robust for listing
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (businessId == request.auth.uid || isStaff());
      }
    }

    match /inquiries/{id} {
      // Publicly allowed to create inquiries for lead generation
      allow create: if true;
      // Only staff can manage inquiries
      allow read, write: if isStaff();
    }

    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff();
    }
  }
}
