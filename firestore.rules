rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    // Businesses and their subcollections
    match /businesses/{businessId} {
      
      // Helper to check ownership of the business doc or its children
      function isBusinessOwner() {
        return isSignedIn() && (
          businessId == request.auth.uid || 
          (resource != null && resource.data.ownerUid == request.auth.uid) ||
          (request.resource != null && request.resource.data.ownerUid == request.auth.uid)
        );
      }

      allow get, update: if isBusinessOwner() || isStaff();
      // Listing top-level businesses (for staff or finding your own)
      allow list: if isSignedIn() && (isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isStaff();

      // Explicitly handle common subcollections for reliability
      match /customers/{customerId} {
        allow read, write: if isBusinessOwner() || isStaff();
      }
      match /activities/{activityId} {
        allow read, write: if isBusinessOwner() || isStaff();
      }
      match /seoMetrics/{metricId} {
        allow read, write: if isBusinessOwner() || isStaff();
      }
      
      // Catch-all for other subcollections
      match /{subcollection}/{docId} {
        allow read, write: if isBusinessOwner() || isStaff();
      }
    }

    // Public Service Inquiries (Lead Gen)
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // Payment/Subscription Records
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff();
    }
  }
}