rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      if (!isSignedIn()) return false;
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) && get(userDocPath).data.role in ['admin', 'staff'];
    }

    // User profiles
    match /users/{userId} {
      allow get, update: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    // Businesses and their subcollections
    match /businesses/{businessId} {
      // Check if user is the business owner (either by path ID or ownerUid field)
      function isBusinessOwner() {
        return isSignedIn() && (businessId == request.auth.uid || (resource != null && resource.data.ownerUid == request.auth.uid));
      }

      allow get, update: if isBusinessOwner() || isStaff();
      // Listing top-level businesses requires ownerUid filter or staff access
      allow list: if isSignedIn() && (isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isStaff();

      // Catch-all for subcollections (customers, activities, seoMetrics)
      match /{subcollection}/{docId} {
        // Allow read if the user owns the parent business (via path or data) or is staff
        allow read: if isSignedIn() && (
          businessId == request.auth.uid || 
          isStaff() || 
          (resource != null && resource.data.ownerUid == request.auth.uid)
        );
        
        // Allow creation if the user owns the parent business
        allow create: if isSignedIn() && (
          businessId == request.auth.uid || 
          isStaff() || 
          request.resource.data.ownerUid == request.auth.uid
        );
        
        // Allow updates and deletes
        allow update, delete: if isSignedIn() && (
          businessId == request.auth.uid || 
          isStaff() || 
          (resource != null && resource.data.ownerUid == request.auth.uid)
        );
      }
    }

    // Public Service Inquiries (Lead Gen)
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // Payment/Subscription Records
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff();
    }
  }
}