rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safe staff check: verifies user document exists and has admin/staff role
    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'client') in ['admin', 'staff'];
    }

    // --- User profiles ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    // --- Businesses and their nested data ---
    match /businesses/{businessId} {
      
      // Ownership check: matches the path ID to the user UID or checks the ownerUid field
      function isOwner() {
        return isSignedIn() && (
          businessId == request.auth.uid || 
          (resource != null && resource.data.get('ownerUid', '') == request.auth.uid)
        );
      }

      // Top level business document rules
      // Path-based 'allow get' is critical for the Dashboard initialization
      allow get: if isSignedIn() && (businessId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner() || isStaff();
      allow delete: if isStaff();

      // Recursive match for all subcollections (customers, activities, metrics, etc.)
      // Using businessId path matching ensures 'list' queries work perfectly for owners.
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (
          businessId == request.auth.uid || 
          isStaff() || 
          (resource != null && resource.data.get('ownerUid', '') == request.auth.uid)
        );
      }
    }

    // --- Public Service Inquiries ---
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (isStaff() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isStaff();
    }
  }
}