rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Defensive staff check: handles cases where user doc might not exist yet
    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    // --- User profiles ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    // --- Businesses and their nested data ---
    match /businesses/{businessId} {
      
      // Top level business document rules
      // Allow read if user is the direct owner (path matches UID), 
      // or if the document's internal ownerUid matches, or if they are staff.
      allow get: if isOwner(businessId) || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid);
      allow list: if isSignedIn() && (isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(businessId) || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid);
      allow delete: if isStaff();

      // Explicit rules for subcollections to ensure 'list' works reliably
      match /customers/{customerId} {
        allow read, write: if isOwner(businessId) || isStaff();
      }
      
      match /activities/{activityId} {
        allow read, write: if isOwner(businessId) || isStaff();
      }

      match /seoMetrics/{metricId} {
        allow read, write: if isOwner(businessId) || isStaff();
      }

      // Catch-all for any other nested data
      match /{allSubcollections=**} {
        allow read, write: if isOwner(businessId) || isStaff();
      }
    }

    // --- Public Service Inquiries ---
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (isStaff() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isStaff();
    }
  }
}