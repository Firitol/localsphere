
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data != null && data.ownerUid == request.auth.uid;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    match /businesses/{businessId} {
      allow get: if isSignedIn() && (businessId == request.auth.uid || isOwner(resource.data) || isStaff());
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(resource.data) || isStaff());
      allow delete: if isStaff();

      // Explicit rules for CRM and Activity subcollections
      match /customers/{customerId} {
        allow read, write: if isSignedIn() && (businessId == request.auth.uid || isOwner(resource.data) || isStaff());
      }
      
      match /activities/{activityId} {
        allow read, write: if isSignedIn() && (businessId == request.auth.uid || isOwner(resource.data) || isStaff());
      }

      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (businessId == request.auth.uid || isOwner(resource.data) || isStaff() || resource == null);
        allow write: if isSignedIn() && (businessId == request.auth.uid || isOwner(resource.data) || isStaff() || (resource == null && request.resource.data.ownerUid == request.auth.uid));
      }
    }

    match /inquiries/{id} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff();
    }
  }
}
