rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      if (!isSignedIn()) return false;
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) && get(userDocPath).data.role in ['admin', 'staff'];
    }

    // User profiles
    match /users/{userId} {
      allow get, update: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    // Businesses and their subcollections
    match /businesses/{businessId} {
      
      // Helper to check ownership of the business doc itself
      function ownsBusiness() {
        return isSignedIn() && (
          businessId == request.auth.uid || 
          (resource != null && resource.data.ownerUid == request.auth.uid) ||
          (request.resource != null && request.resource.data.ownerUid == request.auth.uid)
        );
      }

      allow get, update: if ownsBusiness() || isStaff();
      // Listing top-level businesses
      allow list: if isSignedIn() && (isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isStaff();

      // Subcollections (customers, activities, seoMetrics, etc.)
      match /{subcollection}/{docId} {
        // Explicitly allow read/write if the user owns the parent business.
        // We prioritize path-based matching (businessId == uid) for reliable listing.
        allow read: if isSignedIn() && (
          businessId == request.auth.uid || 
          isStaff() || 
          (resource != null && resource.data.ownerUid == request.auth.uid)
        );
        
        allow write: if isSignedIn() && (
          businessId == request.auth.uid || 
          isStaff() || 
          (request.resource != null && request.resource.data.ownerUid == request.auth.uid) ||
          (resource != null && resource.data.ownerUid == request.auth.uid)
        );
      }
    }

    // Public Service Inquiries (Lead Gen)
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // Payment/Subscription Records
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff();
    }
  }
}