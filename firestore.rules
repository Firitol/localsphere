rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safe staff check: verifies user document exists and has admin/staff role
    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'client') in ['admin', 'staff'];
    }

    // --- User profiles ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    // --- Businesses and their nested data ---
    match /businesses/{businessId} {
      
      // Top level business document rules
      allow get: if isSignedIn() && (businessId == request.auth.uid || isStaff());
      allow list: if isSignedIn() && (isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (businessId == request.auth.uid || isStaff() || (resource != null && resource.data.ownerUid == request.auth.uid));
      allow delete: if isStaff();

      // Subcollections (activities, customers, seoMetrics, etc.)
      // Path-based ownership: If the business document ID matches the user's UID, 
      // they have full access to list and read all nested collections.
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (
          businessId == request.auth.uid || 
          isStaff()
        );
      }
    }

    // --- Public Service Inquiries ---
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (isStaff() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isStaff();
    }
  }
}