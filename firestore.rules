
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy:
     * This ruleset implements a robust, multi-tenant security model for LocalSphere. It relies heavily on 
     * 'Authorization Independence' via denormalization. By copying ownership identifiers (like clientOwnerUserId) 
     * down the document hierarchy, we ensure that every security decision can be made using only the 
     * document's own data (resource.data), avoiding slow and expensive cross-document lookups (get() calls).
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isStaff() {
      return hasRole('staff') || hasRole('admin');
    }

    function isDocClientOwner(data) {
      return isSignedIn() && (data.clientOwnerUserId == request.auth.uid || data.userId == request.auth.uid);
    }

    function isExistingClientOwner(data) {
      return resource != null && (isDocClientOwner(data) || isStaff());
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isStaff()) && resource != null;
      allow delete: if isStaff() && resource != null;
    }

    match /clients/{clientId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isStaff());
      allow update: if isExistingClientOwner(resource.data) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isStaff() && resource != null;

      match /businessProfiles/{businessProfileId} {
        allow get: if isSignedIn() && (resource.data.clientOwnerUserId == request.auth.uid || isStaff());
        allow list: if isSignedIn();
        allow create: if isSignedIn() && (request.resource.data.clientOwnerUserId == request.auth.uid || isStaff());
        allow update: if isExistingClientOwner(resource.data) && (request.resource.data.clientOwnerUserId == resource.data.clientOwnerUserId);
        allow delete: if isStaff() && resource != null;

        match /clientServices/{id} {
          allow get, list: if isSignedIn() && (resource.data.clientOwnerUserId == request.auth.uid || isStaff());
          allow create: if isSignedIn() && (request.resource.data.clientOwnerUserId == request.auth.uid || isStaff());
          allow update: if isExistingClientOwner(resource.data) && (request.resource.data.clientOwnerUserId == resource.data.clientOwnerUserId);
          allow delete: if isStaff() && resource != null;
        }

        match /businessReviews/{id} {
          allow get, list: if isSignedIn() && (resource.data.clientOwnerUserId == request.auth.uid || isStaff());
          allow create: if isSignedIn() && (request.resource.data.clientOwnerUserId == request.auth.uid || isStaff());
          allow update: if isExistingClientOwner(resource.data) && (request.resource.data.clientOwnerUserId == resource.data.clientOwnerUserId);
          allow delete: if isStaff() && resource != null;
        }

        match /seoMetrics/{id} {
          allow get, list: if isSignedIn() && (resource.data.clientOwnerUserId == request.auth.uid || isStaff());
          allow create: if isSignedIn() && (request.resource.data.clientOwnerUserId == request.auth.uid || isStaff());
          allow update: if isExistingClientOwner(resource.data) && (request.resource.data.clientOwnerUserId == resource.data.clientOwnerUserId);
          allow delete: if isStaff() && resource != null;
        }
      }
    }

    match /serviceOfferings/{serviceOfferingId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /inquiries/{inquiryId} {
      allow create: if true; // Public contact form submission
      allow get, list, update, delete: if isStaff(); // Managed by staff
    }
  }
}
