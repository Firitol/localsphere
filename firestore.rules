rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Direct ownership check based on path ID or internal ownerUid
    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId);
    }

    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
    }

    // --- User profiles ---
    match /users/{userId} {
      allow get, create, update: if isSignedIn() && request.auth.uid == userId;
      allow read: if isStaff();
    }

    // --- Businesses and their nested data ---
    match /businesses/{businessId} {
      
      // Allow access if the business document ID matches user UID 
      // OR if the document's internal ownerUid matches.
      allow read, write: if isSignedIn() && (businessId == request.auth.uid || (resource != null && resource.data.ownerUid == request.auth.uid) || isStaff());

      // Simplified subcollection access: Any data under a business path 
      // owned by the user is accessible to that user.
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (businessId == request.auth.uid || isStaff());
      }
    }

    // --- Public Service Inquiries ---
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if isStaff();
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (isStaff() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isStaff();
    }
  }
}