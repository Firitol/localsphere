
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "client"] },
        "ownerUid": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["free", "pending", "active"] },
        "currentPlan": { "type": "string" }
      }
    },
    "Business": {
      "title": "Business",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "category": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "ownerUid": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "businessName": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "default": "ETB" },
        "method": { "type": "string", "enum": ["chapa", "telebirr", "cbe", "manual"] },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "transactionRef": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and subscription status."
    },
    "/businesses/{businessId}": {
      "schema": { "$ref": "#/entities/Business" },
      "description": "Core business profiles."
    },
    "/businesses/{businessId}/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Customer CRM records."
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/Inquiry" },
      "description": "Public service inquiries."
    },
    "/payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Transaction records for auditing and activation."
    }
  }
}
