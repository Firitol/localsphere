
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored information about a registered LocalSphere user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Inquiry": {
      "title": "Service Inquiry",
      "description": "Details from the service inquiry form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "businessName": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "businessName", "service"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profile data."
    },
    "/inquiries/{inquiryId}": {
      "schema": "#/backend/entities/Inquiry",
      "description": "Customer service inquiries."
    }
  }
}
